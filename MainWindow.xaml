<Window x:Class="MusicWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Music Widget"
        Icon="icon.ico"
        Width="340" SizeToContent="Height"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        MouseLeftButtonDown="OnDrag">

    <Window.Resources>
        <Style x:Key="CtrlBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#F2F2F2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="16"
                                Width="32" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#C8C8C8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="4"
                                Width="22" Height="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TextBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#C8C8C8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="4" Padding="6,2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="#E6202020" Padding="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Artwork -->
            <Border Grid.Column="0" Width="64" Height="64" CornerRadius="8"
                    Background="#33FFFFFF" ClipToBounds="True" VerticalAlignment="Top">
                <Image x:Name="Art" Stretch="UniformToFill"/>
            </Border>

            <!-- Right side -->
            <Grid Grid.Column="1" Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Source + actions -->
                <Grid Grid.Row="0" Margin="0,0,0,2">
                    <TextBlock x:Name="Source" Text="Music" Foreground="#9A9A9A" FontSize="11"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="SearchBtn" Style="{StaticResource IconBtn}" Content="&#xE721;"
                                ToolTip="Cari lagu di YouTube" Click="OnToggleSearch"/>
                        <Button x:Name="OpenBtn" Style="{StaticResource IconBtn}" Content="&#xE8E5;"
                                ToolTip="Buka file lagu lokal" Click="OnOpenFile"/>
                        <Button x:Name="CloseBtn" Style="{StaticResource IconBtn}" Content="&#xE711;"
                                ToolTip="Tutup" Click="OnClose"/>
                    </StackPanel>
                </Grid>

                <!-- Title + artist -->
                <StackPanel Grid.Row="1">
                    <TextBlock x:Name="TitleText" Text="Tidak ada yang diputar"
                               Foreground="#F5F5F5" FontSize="14" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="ArtistText" Text=""
                               Foreground="#B5B5B5" FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Progress + controls -->
                <Grid Grid.Row="2" VerticalAlignment="Bottom">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ProgressBar x:Name="Progress" Grid.Row="0" Height="3" Minimum="0" Maximum="1"
                                 Value="0" Foreground="#1DB954" Background="#33FFFFFF"
                                 BorderThickness="0" Margin="0,4,0,4"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="PrevBtn" Style="{StaticResource CtrlBtn}" Content="&#xE100;" Click="OnPrev"/>
                        <Button x:Name="PlayBtn" Style="{StaticResource CtrlBtn}" Content="&#xE768;" Click="OnPlayPause" FontSize="16"/>
                        <Button x:Name="NextBtn" Style="{StaticResource CtrlBtn}" Content="&#xE101;" Click="OnNext"/>
                        <Button x:Name="RepeatBtn" Style="{StaticResource CtrlBtn}" Content="&#xE72C;" FontSize="13"
                                ToolTip="Putar ulang lagu terakhir" Click="OnRepeat"/>
                        <Button x:Name="LoopBtn" Style="{StaticResource CtrlBtn}" Content="&#xE1CD;" FontSize="13"
                                ToolTip="Loop lagu ini" Click="OnToggleLoop"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <!-- Search panel (YouTube) -->
        <StackPanel x:Name="SearchPanel" Visibility="Collapsed" Margin="0,10,0,0">
            <TextBox x:Name="SearchBox" Background="#1A1A1A" Foreground="#F0F0F0"
                     BorderBrush="#444" BorderThickness="1" Padding="6,4" FontSize="12"
                     KeyDown="OnSearchKey" TextChanged="OnSearchTextChanged"/>

            <!-- Tabs + play-all -->
            <Grid Margin="0,6,0,0">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="TabResults" Style="{StaticResource TextBtn}" Content="Hasil" Click="OnTabResults"/>
                    <Button x:Name="TabPlayed" Style="{StaticResource TextBtn}" Content="Riwayat" Click="OnTabPlayed"/>
                </StackPanel>
                <Button x:Name="PlayAllBtn" Style="{StaticResource TextBtn}" HorizontalAlignment="Right"
                        Content="&#x25B6; Putar semua" FontFamily="Segoe UI"
                        ToolTip="Putar semua dari daftar" Click="OnPlayAll"/>
            </Grid>

            <ListBox x:Name="Results" Background="Transparent" BorderThickness="0"
                     Foreground="#E5E5E5" MaxHeight="180" Margin="0,4,0,0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="OnResultPick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Display}" Padding="4,3"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Style="{StaticResource IconBtn}" Content="&#xE711;"
                                    FontSize="10" Visibility="{Binding DeleteVisibility}"
                                    ToolTip="Hapus dari riwayat" Click="OnDeleteItem"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
        </StackPanel>
    </Border>
</Window>
